# insPRO backend ayarları — bu dosyayı .env olarak kopyalayıp doldurun.

# Ortam
APP_ENV=development

# Veritabanı (docker-compose içindeki db servisi için DB_PASSWORD yeterli)
DB_PASSWORD=guclu-bir-sifre

# JWT imza anahtarı — MUTLAKA rastgele uzun bir değerle değiştirin
# Üretmek için: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=degistir-bu-gizli-anahtari

# CORS — frontend adres(ler)i; virgülle ayırın veya geliştirmede *
CORS_ORIGINS=*

# SMTP (e-posta kodu gönderimi) — Gmail uygulama şifresi
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yazeinspro@gmail.com
SMTP_PASSWORD=gmail-uygulama-sifresi
SMTP_FROM=İNŞPRO <yazeinspro@gmail.com>
