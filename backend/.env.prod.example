# insPRO ÜRETİM ayarları — .env olarak kopyalayıp doldurun.
# docker compose -f docker-compose.prod.yml up -d --build

# Güçlü DB parolası
DB_PASSWORD=

# JWT imza anahtarı — MUTLAKA rastgele ve uzun (>=32):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Frontend alan adı (CORS) — virgülle birden fazla; ASLA * kullanmayın
CORS_ORIGINS=https://inspro.example.com

# API'nin yayınlanacağı alan adı (Caddy TLS bunun için sertifika alır)
API_DOMAIN=api.inspro.example.com

# E-posta (OTP) — Gmail uygulama şifresi
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yazeinspro@gmail.com
SMTP_PASSWORD=
SMTP_FROM=İNŞPRO <yazeinspro@gmail.com>

# NOT: YEREL_GIRIS_SIFRE üretimde otomatik kapalıdır (compose'ta boş set edilir).
