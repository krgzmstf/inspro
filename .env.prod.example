# insPRO TAM YIĞIN ÜRETİM — .env olarak kopyalayıp doldurun.
# docker compose -f docker-compose.prod.yml up -d --build

# Alan adları
FRONTEND_DOMAIN=inspro.yazeproje.com
API_DOMAIN=api.inspro.yazeproje.com

# Güçlü DB parolası (rastgele)
DB_PASSWORD=

# JWT imza anahtarı — rastgele, uzun (>=32):
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# E-posta (OTP/2FA) — Gmail uygulama şifresi
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yazeinspro@gmail.com
SMTP_PASSWORD=
SMTP_FROM=İNŞPRO <yazeinspro@gmail.com>
